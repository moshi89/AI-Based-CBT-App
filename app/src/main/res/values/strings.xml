    <!-- EntryScreen -->
    <string name="entry_title">What negative thoughts are troubling you today?</string>
    <string name="entry_subtitle">Write down the pessimistic or anxious thoughts circling your head. We will help analyze and find cognitive distortions.</string>
    <string name="entry_placeholder">e.g., I ruined today\'s interview. I\'ll never get a job and will live miserably...</string>
    <string name="entry_btn">Start AI Analysis</string>
    <string name="entry_template_title">Stuck? Try one of these templates</string>
    <string name="entry_template_1">No matter how hard I try, I always seem to fall behind others...</string>
    <string name="entry_template_2">My friend is replying late. I must have done something wrong...</string>
    <string name="entry_template_3">My appearance is so plain, everyone must be judging me silently...</string>
    <string name="entry_hero_title">Pour out the heavy burdens\nof your mind today</string>
    <string name="entry_hero_subtitle">A quiet sanctuary to freely record your inner anxiety, doubt, and self-criticism.</string>
    <string name="entry_input_placeholder">e.g., Why isn\'t my friend replying.. They must have misunderstood or been disappointed by what I said.. I can\'t focus on anything all day.</string>
    <string name="entry_template_hint">💡 Are you stuck in thoughts like these?</string>
    <string name="entry_tpl_rel_title">Relationship Isolation</string>
    <string name="entry_tpl_rel_body">Why hasn\'t the reply come for 3 hours? They must be ignoring me or wanting to break off the relationship.</string>
    <string name="entry_tpl_ach_title">Achievement Anxiety</string>
    <string name="entry_tpl_ach_body">This exam/interview is absolutely ruined because of my mistake. I am a misfit who will fail every single time.</string>
    <string name="entry_tpl_pub_title">Public Speaking Tension</string>
    <string name="entry_tpl_pub_body">I stumbled over my words in public and embarrassed myself. Everyone there must be marking me as pathetic and laughing.</string>

